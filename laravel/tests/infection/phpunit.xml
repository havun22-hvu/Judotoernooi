<?xml version="1.0" encoding="UTF-8"?>
<!--
    Dedicated PHPUnit config for Infection (mutation testing). Separate from the
    root phpunit.xml on purpose:
      - Only ONE testsuite (the Services unit tests that cover Infection's target
        services). It does NOT overlap the root Unit/Feature suites, so PHPUnit 11
        does not throw "file already added to another testsuite".
      - Strict flags (failOnRisky/failOnWarning/beStrictAboutOutputDuringTests) are
        off: Infection only needs an honest pass/fail, not the project's strictness
        gates. Keeps the initial run small and immune to subprocess-stderr noise.
    Referenced via infection.json5 -> phpUnit.configDir. Paths are relative to this
    file's directory (tests/infection/); Infection absolutises them.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="../../vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="../../vendor/autoload.php"
         colors="true"
         cacheDirectory="../../.phpunit.cache"
         executionOrder="default"
         requireCoverageMetadata="false"
         beStrictAboutCoverageMetadata="false">
    <testsuites>
        <testsuite name="Mutation">
            <directory>../../tests/Unit/Services</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>../../app/Services</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_DEBUG" value="true"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_DRIVER" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
    </php>
</phpunit>
